<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="" readonly="0" foreign_keys="" case_sensitive_like="" temp_store="" wal_autocheckpoint="" synchronous=""/><attached/><window><main_tabs open="structure browser pragmas query" current="0"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="3706"/><column_width id="4" width="0"/></tab_structure><tab_browse><table title="." custom_title="0" dock_id="7" table="0,0:"/><dock_state state=""/><default_encoding codec=""/><browse_table_settings/></tab_browse><tab_sql><sql name="SQL 1*">CREATE TABLE IF NOT EXISTS Employees (
    EmployeeId   TEXT NOT NULL PRIMARY KEY,   -- nvarchar(20) → TEXT
    FullName     TEXT NOT NULL,               -- nvarchar(100) → TEXT
    Email        TEXT,                        -- nvarchar(100) → TEXT
    Mobile       TEXT,                        -- nvarchar(20) → TEXT
    Role         TEXT,                        -- nvarchar(50) → TEXT
    SiteCode     TEXT,                        -- nvarchar(20) → TEXT
    DateCreated  DATETIME DEFAULT (CURRENT_TIMESTAMP), -- getdate() → CURRENT_TIMESTAMP
    SiteId       INTEGER,                     -- int → INTEGER
    Status       TEXT DEFAULT 'Active',       -- nvarchar(10) → TEXT
    LastSynced   DATETIME,                    -- datetime → DATETIME
    LastUpdated  DATETIME,                    -- datetime → DATETIME
    EmployeeNo   TEXT                         -- nvarchar(50) → TEXT
);
</sql><current_tab id="0"/></tab_sql></sqlb_project>

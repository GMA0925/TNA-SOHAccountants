            }

            Log($"💾 Sync interval saved: {syncMinutes} minute(s)", true);
        }

        private void btnManualSync_Click(object sender, EventArgs e)
        {
            int syncedCount = 0;
            string localConnStr = Properties.Settings.Default.LocalSQLiteCon;
            using (var conn = new SQLiteConnection(localConnStr))
            {
                conn.Open();

                // Count total unsynced transactions
                var countCmd = new SQLiteCommand("SELECT COUNT(*) FROM Transactions WHERE Synced = 0", conn);
                int total = Convert.ToInt32(countCmd.ExecuteScalar());

                progressSync.Value = 0;
                progressSync.Maximum = total > 0 ? total : 1;
                progressSync.Visible = true;

                var cmd = new SQLiteCommand("SELECT Id, ReaderId, Timestamp, Payload FROM Transactions WHERE Synced = 0", conn);
                var reader = cmd.ExecuteReader();

                int processed = 0;

                while (reader.Read())
                {
                    int id = Convert.ToInt32(reader["Id"]);
                    string readerId = reader["ReaderId"].ToString();
                    string payload = reader["Payload"].ToString();

                    bool success = PushToCloud(readerId, payload);
                    if (success)
                    {
                        var updateCmd = new SQLiteCommand("UPDATE Transactions SET Synced = 1 WHERE Id = @id", conn);
                        updateCmd.Parameters.AddWithValue("@id", id);
                        updateCmd.ExecuteNonQuery();
                        syncedCount++;
                    }

                    processed++;
                    progressSync.Value = Math.Min(processed, progressSync.Maximum);
                }
            }

            lblSyncStatus.Text = $"✅ Synced {syncedCount} transaction(s)";
            progressSync.Value = 0;
            progressSync.Visible = false;
            LoadUnsyncedTransactions();
        }


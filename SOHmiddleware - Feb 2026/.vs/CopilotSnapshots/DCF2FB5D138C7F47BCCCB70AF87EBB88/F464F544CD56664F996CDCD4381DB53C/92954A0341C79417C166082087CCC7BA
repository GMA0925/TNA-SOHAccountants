        private void SaveToLocalBuffer(ReaderData data)
        {
            try
            {
                if (data == null)
                {
                    Log("⚠️ Attempted to save null data to buffer.");
                    return;
                }
                string localConnStr = Properties.Settings.Default.LocalSQLiteCon;

                using (var conn = new SQLiteConnection(localConnStr))
                {
                    conn.Open();

                    string query = @"
            INSERT INTO ReaderEvents (
                ReaderId, Timestamp, EventType, Value, PayloadRaw,
                CardNumber, PersonName, DeviceIP, IsEmulated, SiteId 
            )
            VALUES (
                @ReaderId, @Timestamp, @EventType, @Value, @PayloadRaw,
                @CardNumber, @PersonName, @DeviceIP, @IsEmulated, @SiteId 
            )";

                    using (var cmd = new SQLiteCommand(query, conn))
                    {
                        cmd.Parameters.AddWithValue("@ReaderId", data.ReaderId);
                        cmd.Parameters.AddWithValue("@Timestamp", data.Timestamp);
                        cmd.Parameters.AddWithValue("@EventType", data.EventType);
                        cmd.Parameters.AddWithValue("@Value", data.Value ?? "");
                        cmd.Parameters.AddWithValue("@PayloadRaw", data.PayloadRaw ?? "");
                        cmd.Parameters.AddWithValue("@CardNumber", data.CardNumber ?? "");
                        cmd.Parameters.AddWithValue("@PersonName", data.PersonName ?? "");
                        cmd.Parameters.AddWithValue("@DeviceIP", data.DeviceIP ?? "");
                        cmd.Parameters.AddWithValue("@IsEmulated", data.IsEmulated ? 1 : 0);
                        cmd.Parameters.AddWithValue("@SiteId", Properties.Settings.Default.SiteID);
                        cmd.ExecuteNonQuery();
                    }

                    Log($"📥 Saved to localbuffer.db: {data.ReaderId} | {data.EventType} | {data.Value}");
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"❌ Error saving to local buffer: {ex.ToString()}");
            }
        }

        private void PushLocalBufferToCloud()
        {
            string localConnStr = Properties.Settings.Default.LocalSQLiteCon;
            string cloudConnStr = Properties.Settings.Default.SQLCon;

            using (var localConn = new SQLiteConnection(localConnStr))
            using (var cloudConn = new SqlConnection(cloudConnStr))
            {
                localConn.Open();
                cloudConn.Open();

                string selectQuery = "SELECT * FROM ReaderEvents";
                using (var selectCmd = new SQLiteCommand(selectQuery, localConn))
                using (var reader = selectCmd.ExecuteReader())
                {
                    while (reader.Read())
                    {
                        // ⚡ Wrap each row sync in a transaction
                        using (var localTx = localConn.BeginTransaction())
                        using (var cloudTx = cloudConn.BeginTransaction())
                        {
                            try
                            {
                                // ☁️ Insert into cloud ReaderEvents (SQL Server)
                                string cloudInsert = @"
                            INSERT INTO ReaderEvents (
                                ReaderId, Timestamp, EventType, Value, PayloadRaw,
                                CardNumber, PersonName, DeviceIP, IsEmulated, SiteId
                            )
                            SELECT @ReaderId, @Timestamp, @EventType, @Value, @PayloadRaw,
                                   @CardNumber, @PersonName, @DeviceIP, @IsEmulated, @SiteId
                            WHERE NOT EXISTS (
                                SELECT 1 FROM ReaderEvents
                                WHERE ReaderId = @ReaderId
                                  AND Timestamp = @Timestamp
                                  AND EventType = @EventType
                                  AND Value = @Value
                            )";

                                using (var cloudCmd = new SqlCommand(cloudInsert, cloudConn, cloudTx))
                                {
                                    cloudCmd.Parameters.AddWithValue("@ReaderId", reader["ReaderId"]);
                                    cloudCmd.Parameters.AddWithValue("@Timestamp", reader["Timestamp"]);
                                    cloudCmd.Parameters.AddWithValue("@EventType", reader["EventType"]);
                                    cloudCmd.Parameters.AddWithValue("@Value", reader["Value"]);
                                    cloudCmd.Parameters.AddWithValue("@PayloadRaw", reader["PayloadRaw"]);
                                    cloudCmd.Parameters.AddWithValue("@CardNumber", reader["CardNumber"]);
                                    cloudCmd.Parameters.AddWithValue("@PersonName", reader["PersonName"]);
                                    cloudCmd.Parameters.AddWithValue("@DeviceIP", reader["DeviceIP"]);
                                    cloudCmd.Parameters.AddWithValue("@IsEmulated", reader["IsEmulated"]);
                                    cloudCmd.Parameters.AddWithValue("@SiteId", Properties.Settings.Default.SiteID);
                                    cloudCmd.ExecuteNonQuery();
                                }

                                // 📦 Archive into local ReaderEventsArchive (SQLite)
                                string archiveInsert = @"
                            INSERT OR IGNORE INTO ReaderEventsArchive (
                                ReaderId, Timestamp, EventType, Value, PayloadRaw,
                                CardNumber, PersonName, DeviceIP, IsEmulated, SiteId
                            )
                            VALUES (
                                @ReaderId, @Timestamp, @EventType, @Value, @PayloadRaw,
                                @CardNumber, @PersonName, @DeviceIP, @IsEmulated, @SiteId
                            )";

                                using (var archiveCmd = new SQLiteCommand(archiveInsert, localConn, localTx))
                                {
                                    archiveCmd.Parameters.AddWithValue("@ReaderId", reader["ReaderId"]);
                                    archiveCmd.Parameters.AddWithValue("@Timestamp", reader["Timestamp"]);
                                    archiveCmd.Parameters.AddWithValue("@EventType", reader["EventType"]);
                                    archiveCmd.Parameters.AddWithValue("@Value", reader["Value"]);
                                    archiveCmd.Parameters.AddWithValue("@PayloadRaw", reader["PayloadRaw"]);
                                    archiveCmd.Parameters.AddWithValue("@CardNumber", reader["CardNumber"]);
                                    archiveCmd.Parameters.AddWithValue("@PersonName", reader["PersonName"]);
                                    archiveCmd.Parameters.AddWithValue("@DeviceIP", reader["DeviceIP"]);
                                    archiveCmd.Parameters.AddWithValue("@IsEmulated", reader["IsEmulated"]);
                                    archiveCmd.Parameters.AddWithValue("@SiteId", Properties.Settings.Default.SiteID);
                                    archiveCmd.ExecuteNonQuery();
                                }

                                // 🗑 Delete from local ReaderEvents
                                string deleteQuery = "DELETE FROM ReaderEvents WHERE Id = @Id";
                                using (var deleteCmd = new SQLiteCommand(deleteQuery, localConn, localTx))
                                {
                                    deleteCmd.Parameters.AddWithValue("@Id", reader["Id"]);
                                    deleteCmd.ExecuteNonQuery();
                                }

                                // ✅ Commit both transactions
                                cloudTx.Commit();
                                localTx.Commit();

                                Log($"☁️ Synced, archived & deleted: {reader["ReaderId"]} | {reader["EventType"]} | {reader["Value"]}");
                                LogSyncSuccess(reader["ReaderId"].ToString(), reader["EventType"].ToString(), "Synced with cloud successfully");
                            }
                            catch (Exception ex)
                            {
                                // ❌ Rollback if anything fails
                                try { cloudTx.Rollback(); } catch { }
                                try { localTx.Rollback(); } catch { }

                                Log($"❌ Sync failed for ID {reader["Id"]}: {ex.Message}", false);
                                LogSyncFailure(reader["CardNumber"].ToString(), reader["PayloadRaw"].ToString(), ex.ToString());
                            }
                        }
                    }
                }
            }
        }





        private void btnCloudConnAccess_Click(object sender, EventArgs e)
        {
            try
            {
                // 🔄 If controls are already enabled, close them
                if (txtCloudConnStr.Enabled && btnSaveCloudConn.Enabled)
                {
                    txtCloudConnStr.Enabled = false;
                    btnSaveCloudConn.Enabled = false;

                    btnCloudConnAccess.Text = "Open Settings";

                    ShowToast("🔒 Cloud SQL settings closed.", Color.Blue);
                    return;
                }

                // 🔒 Create a simple password prompt form
                Form passwordForm = new Form
                {
                    Text = "Admin Authentication Required",
                    StartPosition = FormStartPosition.CenterParent,
                    Width = 400,
                    Height = 180,
                    FormBorderStyle = FormBorderStyle.FixedDialog,
                    MaximizeBox = false,
                    MinimizeBox = false
                };

                Label lblPrompt = new Label
                {
                    Text = "Enter Admin Password:",
                    AutoSize = true,
                    Location = new Point(20, 20)
                };

                TextBox txtPassword = new TextBox
                {
                    Location = new Point(20, 50),
                    Width = 340,
                    UseSystemPasswordChar = true
                };

                Button btnOk = new Button
                {
                    Text = "OK",
                    Location = new Point(200, 90),
                    DialogResult = DialogResult.OK
                };

                Button btnCancel = new Button
                {
                    Text = "Cancel",
                    Location = new Point(280, 90),
                    DialogResult = DialogResult.Cancel
                };

                passwordForm.Controls.Add(lblPrompt);
                passwordForm.Controls.Add(txtPassword);
                passwordForm.Controls.Add(btnOk);
                passwordForm.Controls.Add(btnCancel);

                passwordForm.AcceptButton = btnOk;
                passwordForm.CancelButton = btnCancel;

                // 🖊 Show the password form
                if (passwordForm.ShowDialog(this) == DialogResult.OK)
                {
                    string enteredPassword = txtPassword.Text.Trim();

                    // ✅ Check against stored admin password (replace with secure check)
                    int adminPassword = Properties.Settings.Default.AdminPass;

                    if (enteredPassword == adminPassword.ToString())
                    {
                        ShowToast("✅ Access Granted. Cloud SQL control enabled.", Color.Green);

                        // Enable the protected controls
                        txtCloudConnStr.Enabled = true;
                        btnSaveCloudConn.Enabled = true;

                        // Change button text to "Close Settings"
                        btnCloudConnAccess.Text = "Close Settings";
                    }
                    else
                    {
                        ShowToast("❌ Invalid password. Access denied.", Color.Red);

                        // Keep controls disabled
                        txtCloudConnStr.Enabled = false;
                        btnSaveCloudConn.Enabled = false;

                        // Ensure button text stays "Open Settings"
                        btnCloudConnAccess.Text = "Open Settings";
                    }
                }
            }
            catch (Exception ex)
            {
                ShowToast($"❌ Error: {ex.Message}", Color.Red);
            }
        }



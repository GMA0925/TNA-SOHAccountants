        private void LoadUserCredentials()
        {
            try
            {
                // 🔑 Connect to local SQLite
                string connStr = Properties.Settings.Default.LocalSQLiteCon;
                using (var conn = new SQLiteConnection(connStr))
                {
                    conn.Open();

                    // 🗄 Query for user credentials
                    using (var cmd = new SQLiteCommand("SELECT Username, Password FROM Users WHERE Id = 1", conn))
                    using (var reader = cmd.ExecuteReader())
                    {
                        if (reader.Read())
                        {
                            txtUsernameForm1.Text = reader["Username"].ToString();
                            txtPasswordForm1.Text = reader["Password"].ToString();

                            Log("✅ Loaded user credentials into Form1.");
                        }
                        else
                        {
                            Log("⚠️ No user found with Id = 1.");
                        }
                    }
                }
            }
            catch (SQLiteException sqlex)
            {
                Log($"❌ SQLite error while loading credentials: {sqlex.Message}");
            }
            catch (Exception ex)
            {
                Log($"❌ Unexpected error while loading credentials: {ex.Message}");
            }
        }




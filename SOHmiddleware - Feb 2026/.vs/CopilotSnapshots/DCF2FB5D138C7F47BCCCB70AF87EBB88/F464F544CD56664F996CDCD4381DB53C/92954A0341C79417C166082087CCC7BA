        private void ListenForEvents(CancellationToken token)
        {
            try
            {
                while (!isStopping && listener != null && listener.IsListening && !token.IsCancellationRequested)
                {
                    HttpListenerContext context = null;
                    try
                    {
                        context = listener.GetContext();
                        if (isStopping) // shutdown requested — stop processing further requests
                        {
                            try { context.Response.StatusCode = 503; context.Response.Close(); } catch { }
                            break;
                        }

                        var request = context.Request;

                        using (var reader = new StreamReader(request.InputStream, request.ContentEncoding))
                        {
                            string payload = reader.ReadToEnd();

                            // Log raw payload to file for diagnostics
                            DebugLog($"Received payload: {payload}");

                            // If shutdown started while reading, drop the payload
                            if (isStopping) { try { context.Response.Close(); } catch { } break; }

                            // Use BeginInvoke so the listener thread cannot deadlock waiting on the UI thread.
                            try
                            {
                                if (!isStopping)
                                {
                                    BeginInvoke(new Action(() => ProcessPayload(payload)));
                                }
                            }
                            catch (ObjectDisposedException)
                            {
                                // UI is disposed; stop processing
                                DebugLog("UI disposed while trying to BeginInvoke ProcessPayload.");
                                break;
                            }
                        }

                        try
                        {
                            context.Response.StatusCode = 200;
                            context.Response.Close();
                        }
                        catch { /* ignore response close errors */ }
                    }
                    catch (HttpListenerException)
                    {
                        // Expected when listener is stopped — notify only once
                        if (!isStopping)
                        {
                            try { BeginInvoke(new Action(() => NotifyStoppedOnce("ℹ️ Listener stopped."))); } catch { }
                        }
                        break;
                    }
                    catch (ObjectDisposedException)
                    {
                        // Listener disposed while waiting — treat as intentional shutdown
                        break;
                    }
                    catch (Exception ex)
                    {
                        // Only log unexpected errors when not shutting down
                        DebugLog($"Listener loop error: {ex}");
                        if (!isStopping)
                        {
                            try { BeginInvoke(new Action(() => AppendLog($"❌ Listener error: {ex.Message}"))); } catch { }
                        }
                    }
                }
            }
            catch { /* swallow all exceptions here */ }
            finally
            {
                if (!isStopping)
                {
                    // schedule a restart on threadpool with small delay
                    Task.Delay(1000).ContinueWith(_ => 
                    {
                        if (!isStopping) StartListener(currentPrefix);
                    });
                }
            }
        }

        // Adds a single notification to the listbox (thread-safe)
        private void NotifyStoppedOnce(string message)
        {
            lock (stopLock)
            {
                if (stopNotified) return;
                stopNotified = true;
            }

            AppendLog(message);
        }

        private void ProcessPayload(string payload)
        {
            // 🚫 Exit early if stopping or payload is empty
            if (isStopping || string.IsNullOrWhiteSpace(payload))
                return;

            try
            {
                // 🔍 Extract JSON portion from MIME payload
                string[] parts = payload.Split(
                    new string[] { "--MIME_boundary" },
                    StringSplitOptions.RemoveEmptyEntries
                );

                string jsonPart = null;

                foreach (var part in parts)
                {
                    if (part.Contains("application/json"))
                    {
                        int jsonStart = part.IndexOf('{');
                        int jsonEnd = part.LastIndexOf('}');

                        if (jsonStart != -1 && jsonEnd != -1)
                        {
                            jsonPart = part.Substring(jsonStart, jsonEnd - jsonStart + 1);
                            break;
                        }
                    }
                }

                if (string.IsNullOrEmpty(jsonPart))
                    return;

                // 📦 Parse JSON
                using (JsonDocument doc = JsonDocument.Parse(jsonPart))
                {
                    var root = doc.RootElement;

                    // ⏱ Extract timestamp
                    string dateTimeStr = root.GetProperty("dateTime").GetString();
                    DateTime eventTime = DateTime.Parse(dateTimeStr);

                    // 🎫 Extract AccessControllerEvent details
                    var accessEvent = root.GetProperty("AccessControllerEvent");

                    string name = accessEvent.TryGetProperty("name", out var n) ? n.GetString() : "(unknown)";
                    string employeeNo = accessEvent.TryGetProperty("employeeNoString", out var e) ? e.GetString() : "(none)";
                    string status = accessEvent.TryGetProperty("attendanceStatus", out var s) ? s.GetString() : "undefined";
                    string label = accessEvent.TryGetProperty("label", out var l) ? l.GetString() : "";

                    // 🌐 Device info
                    string deviceIp = root.TryGetProperty("ipAddress", out var ip) ? ip.GetString() : "";
                    string readerId = root.TryGetProperty("deviceID", out var rid) ? rid.GetString() : "";

                    // 🚫 Skip if name is unknown
                    if (name == "(unknown)" || string.IsNullOrWhiteSpace(name))
                        return;

                    // 🖥 Display parsed event
                    string parsed = $"{eventTime:HH:mm:ss} - Name: {name}, Employee#: {employeeNo}, {label}, Time: {dateTimeStr}";
                    lstEvents.Items.Add(parsed);

                    // 🗄 Insert into Local SQLite
                    string localConnStr = Properties.Settings.Default.LocalSQLiteCon;
                    using (var conn = new SQLiteConnection(localConnStr))
                    {
                        conn.Open();

                        // 🔍 Check if employee exists
                        bool employeeExists = false;
                        using (var checkCmd = conn.CreateCommand())
                        {
                            checkCmd.CommandText = "SELECT COUNT(*) FROM Employees WHERE EmployeeNo = $EmployeeNo";
                            checkCmd.Parameters.AddWithValue("$EmployeeNo", employeeNo);

                            long count = (long)checkCmd.ExecuteScalar();
                            employeeExists = count > 0;
                        }

                        // ➕ Insert employee if not exists
                        if (!employeeExists)
                        {
                            using (var insertCmd = conn.CreateCommand())
                            {
                                insertCmd.CommandText = @"
                            INSERT OR IGNORE INTO Employees 
                            (EmployeeId, FullName, DateCreated, Role, SiteCode, Status)
                            VALUES ($EmployeeId, $FullName, $DateCreated, $Role, $SiteCode, $Status);
                        ";

                                insertCmd.Parameters.AddWithValue("$EmployeeId", employeeNo);
                                insertCmd.Parameters.AddWithValue("$FullName", name);
                                insertCmd.Parameters.AddWithValue("$DateCreated", DateTime.Now);
                                insertCmd.Parameters.AddWithValue("$Role", "User");
                                insertCmd.Parameters.AddWithValue("$SiteCode", Properties.Settings.Default.SiteID);
                                insertCmd.Parameters.AddWithValue("$Status", "Active");

                                insertCmd.ExecuteNonQuery();
                            }
                        }

                        // 📥 Insert into ReaderEvents
                        using (var cmd = conn.CreateCommand())
                        {
                            cmd.CommandText = @"
                        INSERT INTO ReaderEvents 
                        (ReaderId, Timestamp, EventType, Value, PayloadRaw, CardNumber, PersonName, DeviceIP, IsEmulated, SiteId)
                        VALUES
                        ($ReaderId, $Timestamp, $EventType, $Value, $PayloadRaw, $CardNumber, $PersonName, $DeviceIP, $IsEmulated, $SiteId);
                    ";

                            cmd.Parameters.AddWithValue("$ReaderId", readerId);
                            cmd.Parameters.AddWithValue("$Timestamp", eventTime);
                            cmd.Parameters.AddWithValue("$EventType", status);
                            cmd.Parameters.AddWithValue("$Value", label);
                            cmd.Parameters.AddWithValue("$PayloadRaw", jsonPart);
                            cmd.Parameters.AddWithValue("$CardNumber", employeeNo);
                            cmd.Parameters.AddWithValue("$PersonName", name);
                            cmd.Parameters.AddWithValue("$DeviceIP", deviceIp);
                            cmd.Parameters.AddWithValue("$IsEmulated", 0);
                            cmd.Parameters.AddWithValue("$SiteId", lblSiteID.Text);

                            cmd.ExecuteNonQuery();
                        }
                    }

                    // ☁️ Try to sync with Cloud SQL
                    bool cloudSynced = false;
                    try
                    {
                        string cloudConnStr = Properties.Settings.Default.SQLCon;
                        using (var cloudConn = new SqlConnection(cloudConnStr))
                        {
                            cloudConn.Open();

                            using (var empCmd = cloudConn.CreateCommand())
                            {
                                empCmd.CommandText = @"
                            IF NOT EXISTS (SELECT 1 FROM Employees WHERE EmployeeId = @EmployeeId)
                            BEGIN
                                INSERT INTO Employees (EmployeeId, FullName, DateCreated, Role, SiteCode, Status)
                                VALUES (@EmployeeId, @FullName, @DateCreated, @Role, @SiteCode, @Status)
                            END
                        ";

                                empCmd.Parameters.AddWithValue("@EmployeeId", employeeNo);
                                empCmd.Parameters.AddWithValue("@FullName", name);
                                empCmd.Parameters.AddWithValue("@DateCreated", eventTime);
                                empCmd.Parameters.AddWithValue("@Role", "User");
                                empCmd.Parameters.AddWithValue("@SiteCode", Properties.Settings.Default.SiteID);
                                empCmd.Parameters.AddWithValue("@Status", "Active");

                                empCmd.ExecuteNonQuery();
                            }

                            cloudSynced = true;
                        }
                    }
                    catch (Exception cloudEx)
                    {
                        lstEvents.Items.Add($"☁️ Cloud sync skipped: {cloudEx.Message}");
                    }

                    // 📦 Archive locally if cloud sync succeeded
                    if (cloudSynced)
                    {
                        using (var archiveConn = new SQLiteConnection(localConnStr))
                        {
                            archiveConn.Open();

                            using (var archiveCmd = archiveConn.CreateCommand())
                            {
                                archiveCmd.CommandText = @"
                            INSERT INTO ReaderEventsArchive
                            (ReaderId, Timestamp, EventType, Value, PayloadRaw, CardNumber, PersonName, DeviceIP, IsEmulated, SiteId)
                            SELECT ReaderId, Timestamp, EventType, Value, PayloadRaw, CardNumber, PersonName, DeviceIP, IsEmulated, SiteId
                            FROM ReaderEvents
                            WHERE CardNumber = $EmployeeNo AND Timestamp = $Timestamp;
                        ";

                                archiveCmd.Parameters.AddWithValue("$EmployeeNo", employeeNo);
                                archiveCmd.Parameters.AddWithValue("$Timestamp", eventTime);

                                archiveCmd.ExecuteNonQuery();
                            }

                            using (var deleteCmd = archiveConn.CreateCommand())
                            {
                                deleteCmd.CommandText = @"
                            DELETE FROM ReaderEvents
                            WHERE CardNumber = $EmployeeNo AND Timestamp = $Timestamp;
                        ";

                                deleteCmd.Parameters.AddWithValue("$EmployeeNo", employeeNo);
                                deleteCmd.Parameters.AddWithValue("$Timestamp", eventTime);

                                deleteCmd.ExecuteNonQuery();
                            }
                        }
                    }
                }

                // 🔄 Refresh local buffer grid
                LoadLocalBufferGrid();
            }
            catch (Exception ex)
            {
                if (!isStopping)
                    lstEvents.Items.Add($"⚠️ Could not parse/insert payload: {ex.Message}");
            }
        }







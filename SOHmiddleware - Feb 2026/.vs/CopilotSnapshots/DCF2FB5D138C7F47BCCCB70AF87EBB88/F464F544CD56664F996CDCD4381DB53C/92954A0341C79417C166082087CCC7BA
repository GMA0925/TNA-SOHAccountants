        private string currentPrefix;
        private void StartListener(string prefix)
        {
            // 🚫 Prevent duplicate listeners
            if (listener != null && listener.IsListening)
            {
                AppendLog("ℹ️ Listener already running, skipping start.");
                return;
            }

            currentPrefix = prefix; // <-- Add this line

            // 1️⃣ Check SQLite availability
            try
            {
                string localConnStr = Properties.Settings.Default.LocalSQLiteCon;
                using (var conn = new SQLiteConnection(localConnStr))
                {
                    conn.Open();
                    AppendLog("✅ SQLite database available.");
                    ShowToast("✅ SQLite database available.", Color.LightGreen);
                }
            }
            catch (Exception ex)
            {
                AppendLog($"❌ SQLite database unavailable: {ex.Message}");
                this.BackColor = Color.Yellow;
                ShowToast($"❌ SQLite database unavailable: {ex.Message}", Color.Red);
                return; // stop further checks if local DB is down
            }

            // 2️⃣ Check Cloud SQL availability
            try
            {
                string cloudConnStr = Properties.Settings.Default.SQLCon;
                using (var cloudConn = new SqlConnection(cloudConnStr))
                {
                    cloudConn.Open();
                    AppendLog("✅ Cloud SQL database available.");
                    ShowToast("✅ Cloud SQL database available.", Color.LightGreen);
                }
            }
            catch (Exception ex)
            {
                AppendLog($"❌ Cloud SQL database unavailable: {ex.Message}");
                this.BackColor = Color.Yellow;
                ShowToast($"❌ Cloud SQL database unavailable: {ex.Message}", Color.Red);
                return; // stop further checks if cloud DB is down
            }

            // 3️⃣ Start Listener
            try
            {
                // 🔧 Initialize listener
                listener = new HttpListener();
                listener.Prefixes.Add(prefix);

                // 🚀 Start listener
                listener.Start();

                // 🧩 Reset flags
                cts = new CancellationTokenSource();
                isStopping = false;
                stopNotified = false;

                // 🎧 Begin listening
                ThreadPool.QueueUserWorkItem(_ => ListenForEvents(cts.Token));

                // ✅ Update UI
                AppendLog($"✅ Listener started on {prefix}");
                lblReaderStatus.ForeColor = Color.Green;
                lblReaderStatus.Text = "Connected successfully...";
                dgvReaders.RowsDefaultCellStyle.BackColor = Color.LightGreen;

                // 🖥 Update form title and background
                this.Text = $"{this.Text} - All readers have been connected and are awaiting data";
                this.BackColor = Color.LightGreen;   // form background goes green
            }
            catch (HttpListenerException hlex)
            {
                AppendLog($"❌ Listener failed: {hlex.Message}");
                this.BackColor = Color.Yellow;

                if (hlex.ErrorCode == 5)
                {
                    AppendLog("⚠️ Try running the app with admin rights or reserve the URL with netsh.");
                }
                else if (hlex.ErrorCode == 32)
                {
                    AppendLog("⚠️ Port 8000 is already in use. Choose another port or stop the conflicting service.");
                }
            }
            catch (Exception ex)
            {
                AppendLog($"❌ Unexpected error starting listener: {ex.Message}");
                this.BackColor = Color.Yellow;
            }
        }





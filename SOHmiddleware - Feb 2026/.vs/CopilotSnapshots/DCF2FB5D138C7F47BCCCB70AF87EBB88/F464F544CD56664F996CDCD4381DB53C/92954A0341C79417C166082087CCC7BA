        private void TryFallbackPort()
        {
            int[] fallbackPorts = { 8001, 8002, 8080 };

            foreach (var port in fallbackPorts)
            {
                try
                {
                    listener = new HttpListener();
                    listener.Prefixes.Add($"http://+:{port}/hikvision/events/");
                    listener.Start();

                    cts = new CancellationTokenSource();
                    isStopping = false;
                    stopNotified = false;

                    ThreadPool.QueueUserWorkItem(_ => ListenForEvents(cts.Token));

                    AppendLog($"✅ Listener started on fallback port {port}");
                    lblReaderStatus.ForeColor = Color.Green;
                    lblReaderStatus.Text = $"Connected on port {port}";
                    return;
                }
                catch
                {
                    AppendLog($"⚠️ Port {port} also unavailable, trying next...");
                }
            }

            AppendLog("❌ No available ports found. Listener could not be started.");
        }

        private void CheckDBLocation()
        {
            try
            {
                // 📂 Define folder and file paths
                string targetFolder = @"C:\SQLdb";
                string sourceFile = Path.Combine(Application.StartupPath, "localbuffer.db");
                string targetFile = Path.Combine(targetFolder, "localbuffer.db");

                // 🗂 Ensure folder exists
                if (!Directory.Exists(targetFolder))
                {
                    Directory.CreateDirectory(targetFolder);
                    ShowToast("📂 SQLdb folder created.", Color.Blue);
                }

                // 📄 Check if localbuffer.db exists in target folder
                if (!File.Exists(targetFile))
                {
                    if (File.Exists(sourceFile))
                    {
                        File.Copy(sourceFile, targetFile, true);
                        ShowToast("✅ localbuffer.db copied to SQLdb folder.", Color.Green);
                    }
                    else
                    {
                        ShowToast("❌ Source localbuffer.db not found in application folder.", Color.Red);
                        return;
                    }
                }
                else
                {
                    ShowToast("ℹ️ localbuffer.db already exists in SQLdb folder. No copy performed.", Color.Blue);
                }

                // 🔑 Update connection string in settings
                string newConnStr = $"Data Source={targetFile};Version=3;";
                Properties.Settings.Default.LocalSQLiteCon = newConnStr;
                Properties.Settings.Default.Save();

                // 🖊 Notify user
                ShowToast("🔄 Local SQLite connection updated and saved.", Color.Green);
            }
            catch (Exception ex)
            {
                ShowToast($"❌ Error during initialization: {ex.Message}", Color.Red);
            }

        }


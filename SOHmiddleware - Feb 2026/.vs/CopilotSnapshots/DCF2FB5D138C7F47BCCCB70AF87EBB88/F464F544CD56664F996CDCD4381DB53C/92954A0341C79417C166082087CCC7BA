        private void ValidateReaderConfigs()
        {
            string configPath = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "ReaderSDK", "Configs");
            if (!Directory.Exists(configPath))
            {
                Log("❌ Config folder not found.", false);
                return;
            }

            var files = Directory.GetFiles(configPath, "*.json");
            if (files.Length == 0)
            {
                Log("⚠️ No config files found.", false);
                return;
            }

            foreach (var file in files)
            {
                try
                {
                    string json = File.ReadAllText(file);
                    var config = JsonConvert.DeserializeObject<ReaderConfig>(json);

                    if (config == null)
                    {
                        Log($"❌ Invalid JSON: {Path.GetFileName(file)}", false);
                        continue;
                    }

                    if (string.IsNullOrWhiteSpace(config.model))
                    {
                        Log($"⚠️ Missing model name in: {Path.GetFileName(file)}", false);
                    }

                    if (config.commands == null || config.commands.Count == 0)
                    {
                        Log($"⚠️ No commands defined in: {Path.GetFileName(file)}", false);
                    }
                    else
                    {
                        var requiredKeys = new[] { "read", "reset", "status", "capture", "verify" };
                        foreach (var key in requiredKeys)
                        {
                            if (!config.commands.ContainsKey(key))
                            {
                                Log($"⚠️ Missing '{key}' command in: {config.model}", false);
                            }
                        }
                    }
                }
                catch (Exception ex)
                {
                    Log($"❌ Error parsing {Path.GetFileName(file)}: {ex.Message}", false);
                }
            }

            Log("✅ Config validation complete.", true);
        }



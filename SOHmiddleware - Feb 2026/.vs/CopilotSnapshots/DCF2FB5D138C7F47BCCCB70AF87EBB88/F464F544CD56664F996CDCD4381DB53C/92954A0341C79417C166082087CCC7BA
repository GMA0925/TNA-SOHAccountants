        public async Task SyncEmployeesToReader(string readerIp, string readerUser, string readerPassword)
        {
            await Task.Run(() =>
            {
                // Initialize SDK
                NET_DVR_Init();

                // Login info struct
                NET_DVR_USER_LOGIN_INFO loginInfo = new NET_DVR_USER_LOGIN_INFO
                {
                    sDeviceAddress = readerIp,
                    wPort = 8000,
                    sUserName = readerUser,
                    sPassword = readerPassword
                };

                NET_DVR_DEVICEINFO_V40 deviceInfo = new NET_DVR_DEVICEINFO_V40();
                int userId = NET_DVR_Login_V40(ref loginInfo, ref deviceInfo);

                if (userId < 0)
                {
                    uint err = NET_DVR_GetLastError();
                    ShowToast($"❌ Login failed, error {err}", Color.OrangeRed);
                    return;
                }

                using (var conn = new SQLiteConnection(Properties.Settings.Default.LocalSQLiteCon))
                {
                    conn.Open();

                    string sql = "SELECT EmployeeId, FullName, SiteCode FROM Employees WHERE Status = 'Active'";
                    using (var cmd = new SQLiteCommand(sql, conn))
                    using (var reader = cmd.ExecuteReader())
                    {
                        while (reader.Read())
                        {
                            int employeeNo = Convert.ToInt32(reader["EmployeeId"]);
                            string personName = reader["FullName"].ToString();

                            NET_DVR_USER_INFO userInfo = new NET_DVR_USER_INFO
                            {
                                dwEmployeeNo = employeeNo,
                                byName = personName,
                                byUserType = 0, // normal
                                byDoorRight = new byte[] { 1, 0, 0, 0 }
                            };

                            bool result = NET_DVR_AddUserInfo(userId, ref userInfo);
                            if (result)
                            {
                                string actionTaken = $"✅ Added {personName} (EmployeeNo {employeeNo}) to {readerIp}";
                                ShowToast(actionTaken, Color.LightGreen);
                                Log(actionTaken);
                            }
                            else
                            {
                                uint err = NET_DVR_GetLastError();
                                string actionTaken = $"⚠️ Failed to add {personName} to {readerIp}, error {err}";
                                ShowToast(actionTaken, Color.OrangeRed);
                                Log(actionTaken);
                            }
                        }
                    }
                }

                NET_DVR_Logout(userId);
                NET_DVR_Cleanup();
            });
        }


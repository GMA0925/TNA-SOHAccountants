        private void LoadLocalBufferGrid()
        {
            string localConnStr = Properties.Settings.Default.LocalSQLiteCon;
            lvLocalTransactions.Items.Clear();

            using (var conn = new SQLiteConnection(localConnStr))
            {
                conn.Open();
                var cmd = new SQLiteCommand(@"
            SELECT PersonName,Timestamp, ReaderId, EventType, Value, PayloadRaw, IsEmulated, SiteId  
            FROM ReaderEvents 
            ORDER BY Timestamp DESC", conn);

                using (var reader = cmd.ExecuteReader())
                {
                    while (reader.Read())
                    {
                        var item = new ListViewItem(Convert.ToDateTime(reader["Timestamp"]).ToString("yyyy-MM-dd HH:mm:ss"));
                        item.SubItems.Add(reader["ReaderId"].ToString());
                        item.SubItems.Add(reader["EventType"].ToString());
                        item.SubItems.Add(reader["Value"].ToString());
                        item.SubItems.Add(reader["PayloadRaw"].ToString());
                        item.SubItems.Add(Convert.ToInt32(reader["IsEmulated"]) == 1 ? "Yes" : "No");
                        item.SubItems.Add(reader["SiteId"].ToString());
                        lvLocalTransactions.Items.Add(item);
                    }

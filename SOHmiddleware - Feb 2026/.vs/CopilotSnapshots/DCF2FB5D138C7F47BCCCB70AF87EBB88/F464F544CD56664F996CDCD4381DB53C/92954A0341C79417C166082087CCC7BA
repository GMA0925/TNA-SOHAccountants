        private void SaveSyncInterval()
        {
            int syncMinutes = (int)nudSyncInterval.Value;
            string connStr = Properties.Settings.Default.SQLCon;

            using (var conn = new SqlConnection(connStr))
            {
                conn.Open();

                // Ensure Settings table exists
                var ensureTableCmd = new SqlCommand(@"
            IF NOT EXISTS (SELECT * FROM INFORMATION_SCHEMA.TABLES WHERE TABLE_NAME = 'Settings')
            BEGIN
                CREATE TABLE Settings (
                    Id INT PRIMARY KEY IDENTITY,
                    SyncIntervalMinutes INT
                )
            END", conn);
                ensureTableCmd.ExecuteNonQuery();

                // Upsert logic
                var cmd = new SqlCommand(@"
            IF EXISTS (SELECT 1 FROM Settings)
                UPDATE Settings SET SyncIntervalMinutes = @minutes
            ELSE
                INSERT INTO Settings (SyncIntervalMinutes) VALUES (@minutes)", conn);


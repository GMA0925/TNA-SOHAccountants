        public async Task<bool> TestHikvisionConnection_WebRequestAsync(string deviceIp, int port, string username, string password)
        {
            string url = $"https://{deviceIp}:{port}/ISAPI/System/status";

            try
            {
                using (var handler = new HttpClientHandler())
                {
                    // Hikvision devices use self-signed certs → ignore SSL errors
                    handler.ServerCertificateCustomValidationCallback = (message, cert, chain, errors) => true;

                    using (var client = new HttpClient(handler))
                    {
                        // Basic Auth header
                        string authInfo = Convert.ToBase64String(System.Text.Encoding.ASCII.GetBytes($"{username}:{password}"));
                        client.DefaultRequestHeaders.Authorization =
                            new System.Net.Http.Headers.AuthenticationHeaderValue("Basic", authInfo);

                        // Send GET request
                        var response = await client.GetAsync(url);

                        if (response.IsSuccessStatusCode)
                        {
                            string result = await response.Content.ReadAsStringAsync();
                            Console.WriteLine("✅ Connected. Payload: " + result);
                            return true;
                        }
                        else
                        {
                            Console.WriteLine($"❌ Connection failed. Status: {response.StatusCode}");
                            return false;
                        }
                    }
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine("❌ Connection failed: " + ex.Message);
                return false;
            }
        }




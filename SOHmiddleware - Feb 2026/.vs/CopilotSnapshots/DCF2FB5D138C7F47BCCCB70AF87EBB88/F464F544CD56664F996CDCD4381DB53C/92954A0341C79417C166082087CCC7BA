        private void LoadDashboardCharts()
        {
            string connStr = Properties.Settings.Default.SQLCon;

            // 1. SQL Buffer Transactions
            try
            {
                chartSqlBuffer.Series.Clear();
                var sqlSeries = new Series("Transactions") { ChartType = SeriesChartType.Line };

                using (SqlConnection conn = new SqlConnection(connStr))
                {
                    conn.Open();
                    string query = @"
                SELECT TOP 7 COUNT(*) AS CountPerMinute, 
                       DATEPART(MINUTE, Timestamp) AS MinuteMark
                FROM Transactions
                WHERE Timestamp >= DATEADD(MINUTE, -10, GETDATE())
                GROUP BY DATEPART(MINUTE, Timestamp)
                ORDER BY MinuteMark";

                    using (SqlCommand cmd = new SqlCommand(query, conn))
                    using (SqlDataReader reader = cmd.ExecuteReader())
                    {
                        while (reader.Read())
                        {
                            string label = $"Min {reader["MinuteMark"]}";
                            int count = Convert.ToInt32(reader["CountPerMinute"]);
                            sqlSeries.Points.AddXY(label, count);
                        }
                    }
                }

                if (sqlSeries.Points.Count == 0)
                    sqlSeries.Points.AddXY("No Data", 0);

                chartSqlBuffer.Series.Add(sqlSeries);
                Log($"✅ SQL buffer chart refreshed with {sqlSeries.Points.Count} points.", true);
            }
            catch (Exception ex)
            {
                Log($"❌ SQL buffer chart error: {ex.Message}", false);
            }

            // 2. Config Validation Status
            try
            {
                chartConfigStatus.Series.Clear();
                var configSeries = new Series("ConfigStatus") { ChartType = SeriesChartType.Pie };

                using (SqlConnection conn = new SqlConnection(connStr))
                {
                    conn.Open();
                    string query = @"
                SELECT IsValid, COUNT(*) AS Count
                FROM ConfigValidationLog
                GROUP BY IsValid";

                    using (SqlCommand cmd = new SqlCommand(query, conn))
                    using (SqlDataReader reader = cmd.ExecuteReader())
                    {
                        while (reader.Read())
                        {
                            string label = (bool)reader["IsValid"] ? "Valid" : "Invalid";
                            int count = Convert.ToInt32(reader["Count"]);
                            configSeries.Points.AddXY(label, count);
                        }
                    }
                }

                if (configSeries.Points.Count == 0)
                    configSeries.Points.AddXY("No Data", 0);

                chartConfigStatus.Series.Add(configSeries);
                Log($"✅ Config status chart refreshed with {configSeries.Points.Count} slices.", true);
            }
            catch (Exception ex)
            {
                Log($"❌ Config status chart error: {ex.Message}", false);
            }

            // 3. SDK Command Results
            try
            {
                chartCommandResults.Series.Clear();
                var sdkSeries = new Series("CommandResults") { ChartType = SeriesChartType.Bar };

                using (SqlConnection conn = new SqlConnection(connStr))
                {
                    conn.Open();
                    string query = @"
                SELECT Result, COUNT(*) AS Count
                FROM Transactions
                GROUP BY Result";

                    using (SqlCommand cmd = new SqlCommand(query, conn))
                    using (SqlDataReader reader = cmd.ExecuteReader())
                    {
                        while (reader.Read())
                        {
                            string result = reader["Result"].ToString();
                            int count = Convert.ToInt32(reader["Count"]);
                            sdkSeries.Points.AddXY(result, count);
                        }
                    }
                }

                if (sdkSeries.Points.Count == 0)
                    sdkSeries.Points.AddXY("No Data", 0);

                chartCommandResults.Series.Add(sdkSeries);
                Log($"✅ SDK command chart refreshed with {sdkSeries.Points.Count} bars.", true);
            }
            catch (Exception ex)
            {
                Log($"❌ SDK command chart error: {ex.Message}", false);
            }

            // 4. Uptime Duration
            try
            {
                chartUptime.Series.Clear();
                var uptimeSeries = new Series("Uptime") { ChartType = SeriesChartType.Line };

                using (SqlConnection conn = new SqlConnection(connStr))
                {
                    conn.Open();
                    string query = "SELECT TOP 1 StartTime FROM SystemSession ORDER BY StartTime DESC";
                    DateTime startTime;

                    using (SqlCommand cmd = new SqlCommand(query, conn))
                    {
                        var result = cmd.ExecuteScalar();
                        startTime = result != null ? Convert.ToDateTime(result) : DateTime.Now;
                    }

                    int totalMinutes = (int)(DateTime.Now - startTime).TotalMinutes;
                    for (int i = 0; i <= 60; i += 10)
                    {
                        uptimeSeries.Points.AddXY($"{i} min", Math.Min(i, totalMinutes));
                    }
                }

                chartUptime.Series.Add(uptimeSeries);
                Log($"✅ Uptime chart refreshed with {uptimeSeries.Points.Count} points.", true);
            }
            catch (Exception ex)
            {
                Log($"❌ Uptime chart error: {ex.Message}", false);
            }
        }




        public void SaveTransactionLocally(string readerId, string payload)
        {
            string localConnStr = Properties.Settings.Default.LocalSQLiteCon;
            using (var conn = new SQLiteConnection(localConnStr))
            {
                conn.Open();
                var cmd = new SQLiteCommand("INSERT INTO Transactions (ReaderId, Timestamp, Payload, Synced,SiteId) VALUES (@id, @ts, @data, 0,@SiteId)", conn);
                cmd.Parameters.AddWithValue("@id", readerId);
                cmd.Parameters.AddWithValue("@ts", DateTime.Now);
                cmd.Parameters.AddWithValue("@data", payload);
                cmd.Parameters.AddWithValue("@SiteId", Properties.Settings.Default.SiteID.ToString());
                cmd.ExecuteNonQuery();
            }
        }

        public void SyncToCloud()
        {
            var unsynced = GetUnsyncedTransactions();
            int total = unsynced.Count;
            int synced = 0;

            Log("🔄 Sync started. Checking for unsynced transactions…");
            lblSyncStatusDash.Text = $"🔄 Syncing {total} transaction(s)…";
            lblSyncStatusDash.ForeColor = Color.DarkOrange;

            progressSync.Value = 0;
            progressSync.Maximum = total > 0 ? total : 1;

            if (total == 0)
            {
                Log("✅ No unsynced transactions found.", true);
                return;
            }

            foreach (var tx in unsynced)
            {
                bool success = PushToCloud(tx);
                if (success)
                {
                    MarkAsSynced(tx.Id);
                    Log($"✅ Tx {tx.Id} synced.", true);
                }
                else
                {
                    Log($"❌ Tx {tx.Id} failed to sync.", false);
                    AddToErrorQueue(tx);
                }

                synced++;
                progressSync.Value = Math.Min(synced, progressSync.Maximum);
            }

            if (errorQueue.Count > 0)
            {
                Log($"⚠️ {errorQueue.Count} transaction(s) failed. Retrying now…");
                RetryFailedSyncs();
            }

            lblSyncStatusDash.Text = $"✅ Sync complete at {DateTime.Now:HH:mm:ss}";
            lblSyncStatusDash.ForeColor = errorQueue.Count > 0 ? Color.Red : Color.Green;

            lblLastSync.Text = $"Last sync: {DateTime.Now:HH:mm:ss}";
            lblFailedCount.Text = $"Failed: {errorQueue.Count}";
            btnRetrySync.Text = $"Retry Failed ({errorQueue.Count})";
            btnRetrySync.Enabled = errorQueue.Count > 0;
        }

        private void RetryFailedSyncs()
        {
            Log($"🔁 Retrying {errorQueue.Count} failed transaction(s)…");

            var retryList = new List<Transaction>(errorQueue);
            errorQueue.Clear();

            foreach (var tx in retryList)
            {
                bool success = PushToCloud(tx);
                if (success)
                {
                    MarkAsSynced(tx.Id);
                    Log($"✅ Retry success: Tx {tx.Id}", true);
                }
                else
                {
                    Log($"❌ Retry failed: Tx {tx.Id}", false);
                    AddToErrorQueue(tx); // Re-queue
                }
            }
            lblSyncStatusDash.Text = $"✅ Sync complete at {DateTime.Now:HH:mm:ss}";
            lblSyncStatusDash.ForeColor = errorQueue.Count > 0 ? Color.Red : Color.Green;

            lblLastSync.Text = $"Last sync: {DateTime.Now:HH:mm:ss}";
            lblFailedCount.Text = $"Failed: {errorQueue.Count}";
            btnRetrySync.Text = $"Retry Failed ({errorQueue.Count})";
            btnRetrySync.Enabled = errorQueue.Count > 0;
        }


        private List<Transaction> errorQueue = new List<Transaction>();

        private void AddToErrorQueue(Transaction tx)
        {
            errorQueue.Add(tx);
        }


        private List<Transaction> GetUnsyncedTransactions()
        {
            var transactions = new List<Transaction>();
            string localConnStr = Properties.Settings.Default.LocalSQLiteCon;

            try
            {
                using (var conn = new SQLiteConnection(localConnStr))
                {
                    conn.Open();
                    var cmd = conn.CreateCommand();
                    cmd.CommandText = "SELECT Id, ReaderId, Timestamp, Payload FROM Transactions WHERE Synced = 0";

                    using (var reader = cmd.ExecuteReader())
                    {
                        while (reader.Read())
                        {
                            transactions.Add(new Transaction
                            {
                                Id = reader.GetInt32(0),
                                ReaderId = reader.GetString(1),
                                Timestamp = reader.GetDateTime(2),
                                Payload = reader.GetString(3)
                            });
                        }
                    }
                }
            }
            catch (Exception ex)
            {
                Log($"❌ Error reading local buffer: {ex.Message}", false);
            }

            return transactions;
        }

        private bool PushToCloud(Transaction transaction)
        {
            string cloudConnStr = Properties.Settings.Default.SQLCon;

            try
            {
                using (var conn = new SqlConnection(cloudConnStr))
                {
                    conn.Open();
                    var cmd = new SqlCommand(@"
                INSERT INTO Transactions (ReaderId, Timestamp, Payload, Source)
                VALUES (@ReaderId, @Timestamp, @Payload, 'LocalSync')", conn);

                    cmd.Parameters.AddWithValue("@ReaderId", transaction.ReaderId);
                    cmd.Parameters.AddWithValue("@Timestamp", transaction.Timestamp);
                    cmd.Parameters.AddWithValue("@Payload", transaction.Payload);

                    cmd.ExecuteNonQuery();
                    return true;
                }
            }
            catch (Exception ex)
            {
                Log($"❌ Cloud push failed for Tx {transaction.Id}: {ex.Message}", false);
                return false;
            }
        }

        public void MarkAsSynced(int id)
        {
            string localConnStr = Properties.Settings.Default.LocalSQLiteCon;

            try
            {
                using (var conn = new SQLiteConnection(localConnStr))
                {
                    conn.Open();
                    var cmd = conn.CreateCommand();
                    cmd.CommandText = "UPDATE Transactions SET Synced = 1 WHERE Id = @id";
                    cmd.Parameters.AddWithValue("@id", id);
                    int rows = cmd.ExecuteNonQuery();
                    Log($"📝 Marked Tx {id} as synced ({rows} row(s) updated).", true);
                }
            }
            catch (Exception ex)
            {
                Log($"❌ Failed to mark Tx {id} as synced: {ex.Message}", false);
            }
        }


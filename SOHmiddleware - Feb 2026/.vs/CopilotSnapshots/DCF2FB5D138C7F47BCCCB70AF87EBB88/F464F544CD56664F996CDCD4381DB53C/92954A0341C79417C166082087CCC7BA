        private bool SaveEmployeeToDatabase(EmployeeDto employee)
        {
            bool success = false;

            try
            {
                using (SqlConnection conn = new SqlConnection(Properties.Settings.Default.SQLCon))
                {
                    string query = @"
                MERGE INTO Employees AS Target
                USING (SELECT @EmployeeId AS EmployeeId) AS Source
                ON Target.EmployeeId = Source.EmployeeId
                WHEN MATCHED THEN
                    UPDATE SET
                        FullName = @FullName,
                        Email = @Email,
                        Mobile = @Mobile,
                        Role = @Role,
                        SiteCode = @SiteCode,
                        Status = @Status,
                        LastUpdated = GETDATE()
                WHEN NOT MATCHED THEN
                    INSERT (EmployeeId, FullName, Email, Mobile, Role, SiteCode, Status, LastUpdated)
                    VALUES (@EmployeeId, @FullName, @Email, @Mobile, @Role, @SiteCode, @Status, GETDATE());
            ";

                    using (SqlCommand cmd = new SqlCommand(query, conn))
                    {
                        cmd.Parameters.AddWithValue("@EmployeeId", employee.EmployeeId);
                        cmd.Parameters.AddWithValue("@FullName", employee.FullName);
                        cmd.Parameters.AddWithValue("@Email", employee.Email ?? "");
                        cmd.Parameters.AddWithValue("@Mobile", employee.Mobile ?? "");
                        cmd.Parameters.AddWithValue("@Role", employee.Role);
                        cmd.Parameters.AddWithValue("@SiteCode", employee.SiteCode);
                        cmd.Parameters.AddWithValue("@Status", employee.Status);
                        cmd.Parameters.AddWithValue("@LastUpdated", employee.LastUpdated);

                        conn.Open();
                        cmd.ExecuteNonQuery();
                        success = true;
                    }
                }
            }
            catch (Exception ex)
            {
                LogSyncFailure(employee.EmployeeId, employee, $"❌ Save failed: {ex.Message}");
                success = false;
            }

            // Post-save actions (only if successful)
            if (success)
            {
                RefreshEmployeeGrid();
                HighlightSavedRow(employee.EmployeeId);
            }

            return success;
        }


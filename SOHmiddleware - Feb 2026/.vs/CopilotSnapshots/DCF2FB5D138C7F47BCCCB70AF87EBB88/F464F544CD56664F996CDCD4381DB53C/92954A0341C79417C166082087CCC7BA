        public List<Reader> LoadReadersFromDatabase()
        {
            // 🗄 Prepare list to hold readers
            var readers = new List<Reader>();

            // 🔑 Connection string from settings
            string connStr = Properties.Settings.Default.SQLCon;

            try
            {
                using (var conn = new SqlConnection(connStr))
                {
                    conn.Open();

                    // 🎯 Only load readers for the current SiteId
                    var cmd = new SqlCommand(@"
                SELECT Id, Make, Model, IPAddress, Port, LastSync, Username, Password, SiteId  
                FROM Readers
                WHERE SiteId = @SiteId", conn);

                    cmd.Parameters.AddWithValue("@SiteId", Properties.Settings.Default.SiteID);

                    using (var reader = cmd.ExecuteReader())
                    {
                        // 🧹 Clear comboBox before adding new items
                        cmdIPEnrol.Items.Clear();

                        while (reader.Read())
                        {
                            // 🧩 Build Reader object
                            var r = new Reader
                            {
                                Id = reader.GetInt32(0),
                                Make = reader.IsDBNull(1) ? "" : reader.GetString(1),
                                Model = reader.IsDBNull(2) ? "" : reader.GetString(2),
                                IPAddress = reader.IsDBNull(3) ? "" : reader.GetString(3),
                                Port = reader.IsDBNull(4) ? "" : reader.GetValue(4).ToString(),
                                LastSync = reader.IsDBNull(5) ? DateTime.MinValue : reader.GetDateTime(5),
                                Username = reader.IsDBNull(6) ? "" : reader.GetString(6),
                                Password = reader.IsDBNull(7) ? "" : reader.GetString(7),
                                SiteId = reader.IsDBNull(8) ? "" : reader.GetValue(8).ToString()
                            };

                            // 🔍 Determine status based on listener state
                            if (listener != null && listener.IsListening)
                            {
                                r.Status = "Connected";
                                r.ConnectAction = "Disconnect";
                            }
                            else
                            {
                                r.Status = "Disconnected";
                                r.ConnectAction = "Connect";
                            }

                            // ➕ Add to list
                            readers.Add(r);

                            // ➕ Also add IP to comboBox
                            if (!string.IsNullOrEmpty(r.IPAddress))
                            {
                                cmdIPEnrol.Items.Add(r.IPAddress);
                            }
                        }
                    }
                }
            }
            catch (Exception ex)
            {
                AppendLog($"❌ Error loading readers: {ex.Message}");
            }

            return readers;
        }



